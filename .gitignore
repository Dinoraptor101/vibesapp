# ===== VIBESAPP MONOREPO .gitignore =====

# ===== NX Framework =====
.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ===== Dependencies =====
node_modules

# ===== Build Outputs =====
# compiled output
dist
tmp
out-tsc
build

# Frontend builds
apps/web/build/
apps/web/dist/

# Backend builds  
apps/api/dist/
apps/api/build/

# Library builds
libs/*/dist/
libs/*/build/

# ===== Environment Files =====
# CRITICAL: NEVER commit actual .env files with secrets!
# Keep only .env.example files for templates

# All .env files except .env.example
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# App-specific environment files
apps/*/.env
apps/*/.env.local
apps/*/.env.development
apps/*/.env.test
apps/*/.env.production
libs/*/.env
libs/*/.env.local

# Keep .env.example files (these are safe templates)
!**/.env.example

# ===== Testing =====
# Test results and reports
test-results/
test-automation/test-results/
test-automation/playwright-report/
libs/e2e-testing/test-results/
libs/e2e-testing/playwright-report/

# Playwright storage state files (authentication cookies)
storageState*.json
libs/e2e-testing/storageState*.json

# Coverage
/coverage
*.lcov

# ===== IDEs and Editors =====
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ===== System Files =====
.DS_Store
Thumbs.db
server/.DS_Store

# ===== Logs and Debug =====
npm-debug.log
yarn-error.log
*.log

# ===== Cache and Temporary =====
/.sass-cache
/connect.lock
/libpeerconnection.log
testem.log
/typings
.cache
.parcel-cache

# ===== React/Frontend Specific =====
# next.js build output  
.next

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# ===== TypeScript =====
*.tsbuildinfo

# ===== Security =====
# Private keys and certificates
*.pem
*.key
*.crt

# ===== Backup Files =====
*.backup
*.bak
*.tmp

# Database backups (NEVER COMMIT)
backups/
libs/e2e-testing/storageState-user1.qa.json
libs/e2e-testing/storageState-user2.qa.json
libs/e2e-testing/test-automation-bot-local-credentials.json
