# ===== VIBESAPP MONOREPO .gitignore =====

# ===== NX Framework =====
.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ===== Dependencies =====
node_modules

# ===== Build Outputs =====
# compiled output
dist
tmp
out-tsc
build

# Frontend builds
apps/web/build/
apps/web/dist/

# Backend builds  
apps/api/dist/
apps/api/build/

# Library builds
libs/*/dist/
libs/*/build/

# ===== Environment Files =====
# Local environment files
.env.local
.env.development.local
.env.test.local
.env.production.local

# App-specific environment files (keep .env.example for templates)
apps/*/.env
apps/*/.env.local

# ===== Testing =====
# Test results and reports
test-results/
test-automation/test-results/
test-automation/playwright-report/
libs/e2e-testing/test-results/
libs/e2e-testing/playwright-report/
storageState.json

# Coverage
/coverage
*.lcov

# ===== IDEs and Editors =====
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ===== System Files =====
.DS_Store
Thumbs.db
server/.DS_Store

# ===== Logs and Debug =====
npm-debug.log
yarn-error.log
*.log

# ===== Cache and Temporary =====
/.sass-cache
/connect.lock
/libpeerconnection.log
testem.log
/typings
.cache
.parcel-cache

# ===== React/Frontend Specific =====
# next.js build output  
.next

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# ===== TypeScript =====
*.tsbuildinfo

# ===== Security =====
# Private keys and certificates
*.pem
*.key
*.crt

# ===== Backup Files =====
*.backup
*.bak
*.tmp
libs/e2e-testing/.env
