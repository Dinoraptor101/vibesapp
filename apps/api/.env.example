# ===== BACKEND ENVIRONMENT CONFIGURATION =====
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Development Environment
NODE_ENV=development

# Server Configuration
PORT=5001
FRONTEND_URL=http://localhost:5173

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-2
AWS_S3_BUCKET=your-s3-bucket-name
CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# API Security
API_KEY=your_api_key_here

# Admin Configuration
ADMIN_PASSWORD=your_secure_admin_password

# reCAPTCHA Configuration (Backend)
RECAPTCHA_SECRET=your_recaptcha_secret_key
ENABLE_RECAPTCHA=false

# E2E Testing Configuration
E2E_BYPASS_TOKEN=your_e2e_bypass_token
QA_TEST_PIGEON_ID=test-pigeon-id-1
QA_TEST_2_PIGEON_ID=test-pigeon-id-2
QA_TEST_USER_ID=test-user-id-1
QA_TEST_USER_2_ID=test-user-id-2

# GitHub Integration (optional)
GITHUB_TOKEN=github_pat_your_token_here

# OpenTelemetry (optional)
POSTHOG_API_KEY=

# Default Settings (optional overrides)
DEFAULT_PAGE_SIZE=20
MAX_IMAGE_SIZE=5242880
MAX_POST_LENGTH=500
