# ===== FRONTEND ENVIRONMENT CONFIGURATION =====
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# All variables must be prefixed with VITE_ to be accessible in the app

# API Configuration
VITE_API_URL=http://localhost:5001/api
VITE_BACKEND_API_KEY=your_backend_api_key

# Firebase Web SDK (Project Settings > General > Your apps > Web SDK config)
# These are NOT secrets — they identify the Firebase project. Real auth is
# enforced by Firebase Auth rules on the project itself.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# CDN & External Services
VITE_CDN_URL=https://your-distribution.cloudfront.net
VITE_GEOCODING_URL=https://nominatim.openstreetmap.org/search

# AWS S3 Configuration (for frontend reference)
VITE_S3_BUCKET=your-s3-bucket-name
VITE_S3_REGION=us-east-2

# reCAPTCHA Configuration (Frontend)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
VITE_ENABLE_RECAPTCHA=false

# Feature Flags
NODE_ENV=development
VITE_USE_SSE=true
VITE_DEBUG=true
VITE_MAINTENANCE_MODE=false
