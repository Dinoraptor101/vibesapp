{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./build",
    "jsx": "react-jsx", // or "react-jsx" for React 17+
    "allowJs": true,
    "checkJs": false
  },
  "include": ["src/**/*", "global.d.ts"],
  "exclude": ["node_modules", "build"]
}
