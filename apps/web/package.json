{
  "name": "vibes",
  "version": "0.20.1",
  "private": true,
  "homepage": "https://vibesapp.net",
  "scripts": {
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "format": "biome format src/ --write",
    "format:check": "biome format src/",
    "check": "biome check src/ --write",
    "lint:ci": "biome ci src/",
    "prebuild": "echo 'Skipping lint check for now'",
    "update-version": "npm version patch && node update-version.ts && git add . && git commit --amend --no-edit && git push",
    "update-version-minor": "npm version minor && node update-version.ts && git add . && git commit --amend --no-edit && git push",
    "start": "serve -s build",
    "build": "tsc && cross-env GENERATE_SOURCEMAP=false react-app-rewired build",
    "test": "react-app-rewired start",
    "eject": "react-scripts eject",
    "logs-qa-frontend": "heroku logs --tail --app vibesapp-frontend",
    "logs-qa-backend": "heroku logs --tail --app vibesapp-backend",
    "logs-prod-backend": "heroku logs --tail --app vibesapp",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@biomejs/biome": "^2.1.3",
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "@types/lodash": "^4.17.20",
    "@types/react-dom": "^18.3.1",
    "@types/react-window": "^1.8.8",
    "axios": "^1.12.0",
    "browser-image-compression": "^2.0.2",
    "cropperjs": "^1.6.2",
    "cross-env": "^10.1.0",
    "customize-cra": "^1.0.0",
    "dompurify": "^3.2.6",
    "html-react-parser": "^5.2.6",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "path-to-regexp": ">=3.3.0",
    "postcss": ">=8.5.6",
    "posthog-js": "^1.259.0",
    "react": "^18.3.1",
    "react-app-rewired": "^2.2.1",
    "react-cookie": "^8.0.1",
    "react-cropper": "^2.3.3",
    "react-dom": "^18.3.1",
    "react-query": "^3.39.3",
    "react-quill-new": "latest",
    "react-router-dom": "^7.6.0",
    "react-scripts": "^5.0.1",
    "react-window": "^1.8.11",
    "serve": "^14.2.5",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "^7.25.7",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.27.1",
    "@babel/plugin-transform-numeric-separator": "^7.25.7",
    "@babel/plugin-transform-optional-chaining": "^7.27.1",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@babel/plugin-transform-private-property-in-object": "^7.27.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "webpack": "^5.102.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
