{
  "name": "vibesapp",
  "version": "0.20.1",
  "description": "Picture based social network",
  "license": "MIT",
  "homepage": "https://vibesapp.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dinoraptor101/vibesapp.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run start:api\" \"npm run start:web-v2\"",
    "start": "cd apps/api && node src/index.js",
    "start:web-v2": "cd apps/web-v2 && npm run dev",
    "start:api": "cd apps/api && npm run dev",
    "build": "echo 'No build step required for Node.js backend'",
    "build:web-v2": "cd apps/web-v2 && npm run build",
    "build:api": "cd apps/api && npm run build",
    "test": "nx test api",
    "test:web-v2": "cd apps/web-v2 && npm test",
    "test:api": "cd apps/api && npm test",
    "test:e2e": "cd libs/e2e-testing && npm test",
    "lint": "nx lint api",
    "lint:web-v2": "cd apps/web-v2 && npm run lint",
    "lint:api": "cd apps/api && npm run lint",
    "lint:fix": "nx lint api --fix",
    "format": "npm run format:web-v2 && npm run format:api && npm run format:e2e && biome format --write libs/shared/src libs/contracts/src scripts",
    "format:check": "npm run format:check:web-v2 && npm run format:check:api && npm run format:check:e2e && biome format libs/shared/src libs/contracts/src scripts",
    "format:web-v2": "cd apps/web-v2 && npm run format",
    "format:api": "cd apps/api && npm run format",
    "format:e2e": "cd libs/e2e-testing && npm run format",
    "format:check:web-v2": "cd apps/web-v2 && npm run format:check",
    "format:check:api": "cd apps/api && npm run format:check",
    "format:check:e2e": "cd libs/e2e-testing && npm run format:check",
    "deploy:web-v2": "cd apps/web-v2 && npm run deploy",
    "deploy:api": "cd apps/api && npm run deploy",
    "deploy:qa": "./scripts/deploy-qa.sh all",
    "deploy:qa:api": "./scripts/deploy-qa.sh backend",
    "deploy:qa:web": "./scripts/deploy-qa.sh frontend",
    "deploy:qa:status": "./scripts/deploy-qa.sh status",
    "deploy:qa:dry-run": "./scripts/deploy-qa.sh --dry-run",
    "build:qa:web": "cd apps/web-v2 && NODE_ENV=production VITE_API_URL=https://api-qa.vibesapp.net/api VITE_CDN_URL=https://d1pegm4swremw5.cloudfront.net VITE_S3_BUCKET=logosil-image-host VITE_S3_REGION=us-east-2 VITE_ENABLE_RECAPTCHA=true VITE_RECAPTCHA_SITE_KEY=6LfpRawqAAAAAAZ_B0K43mzoeqV7haGzqZ06qjxw VITE_USE_SSE=true npm run build",
    "clean": "nx reset && rm -rf node_modules apps/*/node_modules libs/*/node_modules",
    "graph": "nx graph",
    "affected:build": "nx affected:build",
    "affected:test": "nx affected:test",
    "affected:lint": "nx affected:lint",
    "version:patch": "node scripts/update-version.js patch",
    "version:minor": "node scripts/update-version.js minor",
    "version:major": "node scripts/update-version.js major",
    "install:deps": "cd apps/api && npm install --ignore-scripts && cd ../web-v2 && npm install --ignore-scripts",
    "postinstall": "if [ \"$SKIP_POSTINSTALL\" != \"true\" ]; then npm run install:deps; fi"
  },
  "private": true,
  "dependencies": {
    "@nx/js": "^22.0.2",
    "@nx/node": "^22.0.2",
    "@nx/react": "^22.0.2",
    "@nx/webpack": "^22.0.2",
    "concurrently": "^9.2.1",
    "nx": "22.0.2"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "social-network",
    "react",
    "nodejs",
    "mongodb",
    "monorepo",
    "nx",
    "typescript"
  ]
}
