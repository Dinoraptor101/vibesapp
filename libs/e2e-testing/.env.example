# ===== E2E TESTING ENVIRONMENT CONFIGURATION =====
# For local development: Copy this file to .env and fill in your actual values.
# For CI/CD (e.g., GitHub Actions): Environment variables are provided by the CI system—no .env file is needed.
# NEVER commit .env to version control

# ENVIRONMENT TO RUN TESTS AGAINST
ENVIRONMENT=local

# Backend API Key for authenticated test cleanup
BACKEND_API_KEY=your_backend_api_key

# ===== TEST ACCOUNT CREDENTIALS =====
# QA and local use same Database and Test account
QA_TEST_PIGEON_ID=test-pigeon-id-1

# Second test user for multi-user interactions
QA_TEST_2_PIGEON_ID=test-pigeon-id-2

# ===== ENVIRONMENT CONFIGURATION =====
# playwright.config.ts - Local environment (default)
# Change ENVIRONMENT variable above to 'qa' for QA testing

# Localhost URLs (default)
LOCAL_FRONTEND_URL=http://localhost:5173
LOCAL_BACKEND_URL=http://localhost:5001/api
LOCAL_BACKEND_BASE=http://localhost:5001
LOCAL_COOKIE_DOMAIN=localhost

# QA Environment URLs
QA_FRONTEND_URL=https://qa.vibesapp.net
QA_BACKEND_URL=https://api-qa.vibesapp.net/api
QA_BACKEND_BASE=https://api-qa.vibesapp.net
QA_COOKIE_DOMAIN=qa.vibesapp.net

# Admin Configuration (for admin tests)
ADMIN_PASSWORD=your_admin_password

# reCAPTCHA (for testing login flows)
VITE_ENABLE_RECAPTCHA=false

# Debug Options
VERBOSE_E2E_LOGGING=false
